# Procedure for Insert

```sql
DELIMITER //

CREATE PROCEDURE AddEmployee(
    IN emp_id INT,
    IN emp_name VARCHAR(50),
    IN emp_salary FLOAT
)
BEGIN
    INSERT INTO employees(id, name, salary)
    VALUES(emp_id, emp_name, emp_salary);
END //

DELIMITER ;
```

